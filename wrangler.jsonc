{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rocky-github-preview",
  "main": "./worker.mjs",
  "compatibility_date": "2026-07-15",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./WEBSITE",
    "binding": "ASSETS",
    "run_worker_first": ["/ask-rocky"]
  }
}
